# ========== API 配置 ==========
# 在 models.yaml 中用 ${ZAI_API_KEY} 引用这些变量
ZAI_API_KEY=your_api_key_here
MINIMAX_API_KEY=your_api_key_here
KIMI_API_KEY=your_api_key_here

# ========== 评分配置 ==========
# 是否启用加权评分（包含 reasoning_completeness, method_elegance 等维度）
# false = 仅使用答案正确性评分（100%权重）
# true = 使用多维度加权评分
WEIGHTED_SCORING=false

# ========== 调度配置 ==========
# 是否启用定时调度
SCHEDULER_ENABLED=false
# Cron 表达式（默认每天凌晨 2 点）
SCHEDULER_CRON=0 2 * * *
# 要评测的模型列表（逗号分隔）
SCHEDULER_MODELS=glm/glm-4.7
# 要评测的维度（逗号分隔，all 表示全部）
SCHEDULER_DIMENSIONS=all
# 每个维度的题目数量
SCHEDULER_SAMPLES=15

# ========== HuggingFace 代理 ==========
# HF_PROXY=http://proxy:port
# 数据集离线模式（deploy.sh 自动管理，检测到 dataset/.download-complete 时自动启用）
# HF_DATASETS_OFFLINE=0

# ========== 异步评分系统配置 ==========
# 评分后端类型: "qwen_cli" 或 "llm_api"
SCORING_BACKEND_TYPE=qwen_cli

# qwen cli 配置
QWEN_CLI_PATH=qwen
QWEN_TIMEOUT=300

# LLM API 评分配置（当 SCORING_BACKEND_TYPE=llm_api 时使用）
SCORING_API_KEY=
SCORING_API_BASE=https://api.openai.com/v1
SCORING_MODEL=gpt-4

# Worker 配置
SCORING_WORKER_ENABLED=true
SCORING_WORKER_POLL_INTERVAL=5
SCORING_WORKER_BATCH_SIZE=10
SCORING_WORKER_MAX_RETRIES=3
SCORING_WORKER_MAX_CONCURRENCY=3
SCORING_WORKER_COMPLETION_DELAY=10

# ========== 限流重试配置 ==========
# 429 限流首次重试间隔（秒），后续按指数退避: initial * 2^attempt
RATE_LIMIT_INITIAL_BACKOFF=5
# 429 限流最大重试间隔（秒）
RATE_LIMIT_MAX_BACKOFF=120
